TZ=UTC
PORT=3333
HOST=localhost
APP_NAME=adonisjs-mongoose-demo
LOG_LEVEL=info
APP_KEY=
NODE_ENV=development

# adonisjs-mongoose connections
# MONGO_CONNECTION is optional and defaults to "primary".
MONGO_CONNECTION=primary
MONGO_URI=mongodb://127.0.0.1:27017/demo_primary
MONGO_ANALYTICS_URI=mongodb://127.0.0.1:27017/demo_analytics
