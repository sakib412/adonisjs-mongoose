{
  "name": "adonisjs-mongoose",
  "version": "0.2.1",
  "description": "Mongoose ODM integration for AdonisJS — config-driven multiple connections, container-managed manager, models, ace command, REPL bindings and health checks.",
  "type": "module",
  "license": "MIT",
  "author": "Najmus Sakib <nazmusakib412@gmail.com>",
  "homepage": "https://github.com/sakib412/adonisjs-mongoose#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sakib412/adonisjs-mongoose.git",
    "directory": "packages/adonisjs-mongoose"
  },
  "bugs": {
    "url": "https://github.com/sakib412/adonisjs-mongoose/issues"
  },
  "keywords": [
    "adonisjs",
    "adonis",
    "adonisjs-v7",
    "mongoose",
    "mongodb",
    "odm",
    "database"
  ],
  "exports": {
    ".": "./build/index.js",
    "./model": "./build/define_model.js",
    "./mongo_provider": "./build/providers/mongo_provider.js",
    "./services/main": "./build/services/main.js",
    "./commands": "./build/commands/main.js",
    "./types": "./build/types.js"
  },
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "files": [
    "build",
    "!build/**/*.tsbuildinfo",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "rm -rf build && tsc -p tsconfig.build.json && node scripts/copy-stubs.mjs",
    "dev": "tsc -p tsconfig.build.json --watch",
    "clean": "rm -rf node_modules build .turbo",
    "lint": "eslint .",
    "check-types": "tsc --noEmit -p tsconfig.build.json",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@adonisjs/core": "^7.0.0",
    "mongoose": "^9.0.0"
  },
  "devDependencies": {
    "@adonisjs/core": "^7.3.4",
    "@adonisjs/eslint-config": "^3.1.0",
    "@adonisjs/prettier-config": "^1.4.5",
    "@adonisjs/tsconfig": "^2.0.0",
    "@types/node": "~25.6.2",
    "eslint": "^10.4.1",
    "mongoose": "^9.6.3",
    "prettier": "^3.8.1",
    "typescript": "~6.0.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "prettier": "@adonisjs/prettier-config"
}